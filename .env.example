# Copy this file to .env and fill in the keys you use.
#   cp .env.example .env
#
# Only set the providers you actually call. Unused keys can stay blank.

# Anthropic (Claude) — required for claude-agent-sdk / main.py
ANTHROPIC_API_KEY=

# OpenAI (GPT, o-series)
OPENAI_API_KEY=

# Google (Gemini)
GOOGLE_API_KEY=

# Mistral
MISTRAL_API_KEY=

# Cohere
COHERE_API_KEY=

# Optional: Azure OpenAI (if you use Azure instead of api.openai.com)
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
